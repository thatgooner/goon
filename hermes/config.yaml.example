# hermes agent config — copy to config.yaml and fill in your values
# API keys go in .env, not here

model:
  provider: "nousresearch"    # or openrouter, openai, custom
  name: ""                     # model name
  temperature: 0.7
  max_tokens: 4096

terminal:
  backend: "local"             # local, docker, ssh, modal, daytona

personality: "gooner"

tools:
  enabled:
    - web_search
    - web_extract
    - terminal
    - read_file
    - write_file
    - patch
    - search_files
    - memory
    - skills_list
    - skill_view
    - skill_manage
    - execute_code

# mcp_servers:
#   - name: ""
#     command: ""
#     args: []
