# copy to .env and fill in your keys
# NEVER commit .env to git

# ── required ──
OPENROUTER_API_KEY=

# ── messaging gateway ──
TELEGRAM_BOT_TOKEN=

# ── browser / scraping ──
BROWSERBASE_API_KEY=
FIRECRAWL_API_KEY=

# ── voice ──
VOICE_TOOLS_OPENAI_KEY=

# ── image gen ──
FAL_KEY=

# ── LLM providers (optional fallbacks) ──
GLM_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=

# ── experiment tracking ──
WANDB_API_KEY=

# ── other services ──
HONCHO_API_KEY=
TINKER_API_KEY=

# ── hermes runtime (set automatically, rarely need to touch) ──
# HERMES_EXEC_ASK=
# HERMES_MAX_ITERATIONS=
# HERMES_QUIET=
# MEMORY_PRESSURE_WATCH=
